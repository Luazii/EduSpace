@model LearniVerseNew.Models.ApplicationModels.ViewModels.ProgressCenterViewModel

@{
    ViewBag.Title = "Progress Centre";
}

<div class="container mt-5" style="max-width:680px">
    <h2 class="mb-2">Progress Centre</h2>
    <p class="text-muted mb-5">Select a course to view your detailed performance breakdown.</p>

    @if (!Model.Courses.Any())
    {
        <div class="alert alert-info">You are not enrolled in any courses yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var course in Model.Courses)
            {
                <a href="@Url.Action("ViewProgress", "Students", new { courseId = course.CourseID })"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                    <div>
                        <div class="fw-semibold">@course.CourseName</div>
                        <div class="text-muted small">@course.Department &bull; Semester @course.Semester</div>
                    </div>
                    <span class="text-muted">&#8250;</span>
                </a>
            }
        </div>
    }
</div>
